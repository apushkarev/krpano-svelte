<krpano
	debugjsactions="true"
>
	
	<action name="startup0" init_run_before_start="false">
	
		/* Надо для работы тура */
		
		/* делает нормальную консоль */
		if (device.desktop,
			invoke('setKRPanoConsole');
		);

		/* парсит урл */
		invoke('readURL');

		delayedcall (0.5,
			callwith(layer[menu_button_background], show);
		);

		menu.create_items();
		
	</action>
	
</krpano>
